{
    "name": "gravity-tables/gravity-tables",
    "description": "Advanced WordPress plugin for creating dynamic, editable tables from Gravity Forms entries",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.0",
        "phpoffice/phpspreadsheet": "^2.0",
        "freemius/wordpress-sdk": "^2.13.2",
        "halaxa/json-machine": "^1.2"
    },
    "autoload": {
        "psr-4": {
            "GravityTables\\": "includes/"
        }
    },
    "config": {
        "vendor-dir": "vendor",
        "optimize-autoloader": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "mockery/mockery": "^1.6",
        "10up/wp_mock": "0.4.2",
        "brianium/paratest": "^6.11",
        "phpstan/phpstan": "^2",
        "szepeviktor/phpstan-wordpress": "^2.0"
    }
}
