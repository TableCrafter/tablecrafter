+// Minimal wpdb stub for replace_rows / get_rows tests.
+class TC_Wpdb_Stub_2370 {
+    public string $prefix   = 'wp_';
+    public int    $insert_id = 0;
+
+    /** In-memory row storage: [ table_id => [ ['table_id','row_index','row_json'], ... ] ] */
+    private array $storage = [];
+
+    public function prepare( string $sql, ...$args ): string {
+        return vsprintf(
+            str_replace( [ '%d', '%s' ], [ '%d', "'%s'" ], $sql ),
+            array_map( fn( $v ) => is_int( $v ) ? $v : addslashes( (string) $v ), $args )
+        );
+    }
+
+    public function get_results( string $sql, $mode = ARRAY_A ): array {
+        if ( preg_match( '/WHERE table_id = (\d+)/i', $sql, $m ) ) {
+            $tid  = (int) $m[1];
+            $rows = $this->storage[ $tid ] ?? [];
+            usort( $rows, fn( $a, $b ) => (int) $a['row_index'] <=> (int) $b['row_index'] );
+            return $rows;
+        }
+        return [];
+    }
+
+    public function get_var( string $sql ) { return null; }
+
+    public function insert( string $table, array $data, array $fmt = [] ): int {
+        $tid = (int) ( $data['table_id'] ?? 0 );
+        $this->storage[ $tid ][] = $data;
+        return 1;
+    }
+
+    public function delete( string $table, array $where, array $fmt = [] ): int {
+        $tid = isset( $where['table_id'] ) ? (int) $where['table_id'] : null;
+        if ( $tid !== null ) { $this->storage[ $tid ] = []; }
+        return 0;
+    }
+
+    public function update( string $table, array $data, array $where, $fmt = [], $wfmt = [] ): int {
+        return 1;
+    }
+
+    public function get_charset_collate(): string { return ''; }
+}
