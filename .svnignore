# Files EXCLUDED from the WordPress.org SVN trunk (used by sync_svn.sh rsync).
# Keep parity with .distignore: ship only runtime plugin files.

# Version control / CI
.git
.gitignore
.gitattributes
.github
.distignore
.svnignore

# OS / editor cruft
.DS_Store
.vscode
.idea
*.swp

# Dependencies (dev only)
node_modules
vendor
composer.json
composer.lock
package.json
package-lock.json
.eslintrc.js

# Test harness & tooling
tests
.phpunit.cache
.phpunit.result.cache
phpunit.xml.dist
playwright.config.js
playwright-report
test-results
scripts
reports
sync_svn.sh

# Standalone dev/test scripts at repo root
test-*.php
test-*.js
test-*.html
test_*.php
run-*.php
run-*.js
validate-*.php
simple-test.php
tdd-demo.php
run-tdd-green-test.php
make_banner.php

# Backup / dead / stray files
*.backup
*.bak
*.orig
*~

# Documentation not shipped (readme.txt IS shipped)
README.md
CHANGELOG.md
docs

# Marketing / capture assets not needed at runtime
screenshot-*.png

# Logs, archives, build artifacts
*.log
*.zip
*.map
